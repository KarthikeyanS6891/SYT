# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/syt_marketplace

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_string
JWT_REFRESH_SECRET=change_me_refresh_secret_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Sign-In (Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID, type "Web application")
GOOGLE_CLIENT_ID=

# Storage: "local" or "s3"
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
PUBLIC_URL=http://localhost:5000

# AWS S3 (used when STORAGE_DRIVER=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
